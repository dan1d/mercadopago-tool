## Required
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-your-access-token-here

## Telegram (optional — remove to disable)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

## WhatsApp (optional — remove to disable)
WHATSAPP_ACCESS_TOKEN=your-meta-graph-api-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token

## Payment notifications via WhatsApp (optional)
WA_NOTIFY_PHONE=5491155551234

## WhatsApp X-Hub-Signature-256 validation (optional — Meta app secret)
# WHATSAPP_APP_SECRET=your-meta-app-secret

## WhatsApp access control (optional — comma-separated phone numbers, omit to allow all)
# WHATSAPP_ALLOWED_PHONES=5491155551234,5491166662345

## MP Webhook signature validation (optional)
MERCADO_PAGO_WEBHOOK_SECRET=your-webhook-secret

## Telegram access control (optional — comma-separated chat IDs, omit to allow all)
# TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321

## Telegram payment notifications (optional — chat ID to receive payment alerts)
# TELEGRAM_NOTIFY_CHAT_ID=123456789

## Config
MP_CURRENCY=ARS
MP_SUCCESS_URL=https://yoursite.com/thanks
PORT=3000
